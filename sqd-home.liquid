{%- comment -%} SQD bold-dark homepage {%- endcomment -%}
{%- assign mock = 'https://lustrous-cascaron-d921cf.netlify.app/mock/' -%}
<style>
.sqh{--neon:#39ff14;--bg:#07090a;--bg2:#0c0f0e;background:var(--bg);color:#fff;font-family:inherit}
.sqh *{box-sizing:border-box}
.sqh a{text-decoration:none}
.sqh-btn{display:inline-block;background:var(--neon);color:#04210a;font-weight:900;text-transform:uppercase;letter-spacing:.06em;padding:16px 32px;border-radius:8px;font-size:14px;transition:transform .15s}
.sqh-btn:hover{transform:translateY(-2px)}
.sqh-btn.ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.3)}
.sqh-btn.lg{padding:18px 42px;font-size:15px}
.sqh-hero{position:relative;min-height:94vh;display:flex;align-items:center;padding:90px 6vw 40px;background:radial-gradient(120% 90% at 80% 30%,rgba(57,255,20,.10),transparent 60%),var(--bg)}
.sqh-hin{display:grid;grid-template-columns:1.1fr .9fr;gap:30px;align-items:center;max-width:1300px;margin:0 auto;width:100%}
.sqh-eye{color:var(--neon);font-weight:800;letter-spacing:.35em;font-size:12px;text-transform:uppercase;margin-bottom:18px}
.sqh-hero h1{font-size:clamp(46px,8.5vw,108px);line-height:.92;font-weight:900;letter-spacing:-.02em;text-transform:uppercase;margin:0 0 22px;color:#fff!important}
.sqh-hero h1 span{color:var(--neon)}
.sqh-hero p{color:#aab2ad;font-size:clamp(15px,1.4vw,19px);max-width:440px;line-height:1.6;margin:0 0 30px}
.sqh-btns{display:flex;gap:14px;flex-wrap:wrap}
.sqh-himg{position:relative;text-align:center}
.sqh-himg::before{content:'';position:absolute;inset:-6% 10%;background:radial-gradient(circle,rgba(57,255,20,.18),transparent 65%);filter:blur(20px)}
.sqh-himg img{position:relative;width:100%;max-width:430px;filter:drop-shadow(0 40px 60px rgba(0,0,0,.6))}
.sqh-marq{background:var(--neon);color:#04210a;overflow:hidden;white-space:nowrap}
.sqh-mi{display:inline-block;padding:14px 0;animation:sqhm 24s linear infinite;font-weight:900;text-transform:uppercase;letter-spacing:.08em;font-size:14px}
.sqh-mi span{padding:0 24px}
@keyframes sqhm{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.sqh-sec{padding:96px 6vw}
.sqh-wrap{max-width:1300px;margin:0 auto}
.sqh-h2{font-size:clamp(30px,5vw,58px);font-weight:900;text-transform:uppercase;letter-spacing:-.01em;line-height:1;margin:0 0 12px}
.sqh-h2 em{color:var(--neon);font-style:normal}
.sqh-lead{color:#9aa39c;font-size:17px;max-width:520px;margin:0 0 46px}
.sqh-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:30px}
.sqh-cell{background:linear-gradient(180deg,#11150f,#0a0d0c);border:1px solid #1c211d;border-radius:18px;padding:26px;display:flex;align-items:center;justify-content:center;transition:transform .2s,border-color .2s}
.sqh-cell:hover{transform:translateY(-6px);border-color:rgba(57,255,20,.5)}
.sqh-cell img{width:100%;max-width:230px}
.sqh-center{text-align:center;margin-top:48px}
.sqh-steps{background:var(--bg2)}
.sqh-sg{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:30px}
.sqh-step{border-top:2px solid var(--neon);padding-top:22px}
.sqh-step b{display:block;color:var(--neon);font-size:15px;font-weight:900;letter-spacing:.1em;margin-bottom:12px}
.sqh-step h3{font-size:21px;font-weight:800;text-transform:uppercase;margin:0 0 8px;color:#fff!important}
.sqh-step p{color:#9aa39c;font-size:15px;line-height:1.55;margin:0}
.sqh-cta{text-align:center;padding:110px 6vw;background:radial-gradient(120% 100% at 50% 0,rgba(57,255,20,.10),transparent 55%),var(--bg)}
.sqh-cta .sqh-h2{margin-bottom:26px}
@media(max-width:820px){.sqh-hin{grid-template-columns:1fr;text-align:center}.sqh-hero{min-height:auto;padding:104px 22px 46px}.sqh-hero p{margin-left:auto;margin-right:auto}.sqh-btns{justify-content:center}.sqh-himg{order:-1;margin-bottom:8px}.sqh-himg img{max-width:280px}.sqh-grid{grid-template-columns:1fr 1fr;gap:14px}.sqh-cell{padding:16px}.sqh-sg{grid-template-columns:1fr;gap:16px}.sqh-sec{padding:62px 22px}}
/* dark header on homepage */
.hdt-main-header{background:#07090a!important;box-shadow:none!important;border-bottom:1px solid #1b201c!important}
.hdt-main-header a,.hdt-main-header .hdt-menu-link,.hdt-main-header span{color:#fff!important}
.hdt-main-header svg{color:#fff!important;fill:currentColor!important}
.hdt-logo-img{filter:brightness(0) invert(1)}
.hdt-top-bar{background:#0a0c0b!important}
.hdt-top-bar,.hdt-top-bar *{color:#cfd4d0!important}
</style>
<div class="sqh">
 <section class="sqh-hero"><div class="sqh-hin">
  <div>
   <div class="sqh-eye">SQD Sportswear</div>
   <h1>Your club.<br><span>Your kit.</span></h1>
   <p>Design a full custom strip in minutes &mdash; shirt, shorts, socks and all printing included. From just &pound;25.</p>
   <div class="sqh-btns"><a class="sqh-btn" href="/pages/kit-builder">Design Your Kit</a><a class="sqh-btn ghost" href="/collections">Club Stores</a></div>
  </div>
  <div class="sqh-himg"><img src="{{ mock }}mancity2hero.png" alt="Custom football kit"></div>
 </div></section>
 <div class="sqh-marq"><div class="sqh-mi"><span>200+ Designs</span>&bull;<span>All Printing Included</span>&bull;<span>&pound;25 Per Full Strip</span>&bull;<span>Fast Turnaround</span>&bull;<span>Club Stores</span>&bull;<span>200+ Designs</span>&bull;<span>All Printing Included</span>&bull;<span>&pound;25 Per Full Strip</span>&bull;<span>Fast Turnaround</span>&bull;<span>Club Stores</span>&bull;</div></div>
 <section class="sqh-sec"><div class="sqh-wrap">
  <div class="sqh-h2">Endless <em>possibilities</em></div>
  <div class="sqh-lead">Over 200 designs, every one fully recolourable to your club&rsquo;s identity.</div>
  <div class="sqh-grid">
   <a class="sqh-cell" href="/pages/kit-builder"><img src="{{ mock }}arsenal3away.png"></a>
   <a class="sqh-cell" href="/pages/kit-builder"><img src="{{ mock }}valenciathird.png"></a>
   <a class="sqh-cell" href="/pages/kit-builder"><img src="{{ mock }}intermilanhome.png"></a>
   <a class="sqh-cell" href="/pages/kit-builder"><img src="{{ mock }}galatasarayhome.png"></a>
   <a class="sqh-cell" href="/pages/kit-builder"><img src="{{ mock }}chelsea1home.png"></a>
   <a class="sqh-cell" href="/pages/kit-builder"><img src="{{ mock }}acmilanhome.png"></a>
  </div>
  <div class="sqh-center"><a class="sqh-btn lg" href="/pages/kit-builder">Open the Builder</a></div>
 </div></section>
 <section class="sqh-sec sqh-steps"><div class="sqh-wrap">
  <div class="sqh-h2">How it <em>works</em></div>
  <div class="sqh-sg">
   <div class="sqh-step"><b>01</b><h3>Pick a design</h3><p>Choose from 200+ patterns &mdash; stripes, hoops, geometric, camo and more.</p></div>
   <div class="sqh-step"><b>02</b><h3>Make it yours</h3><p>Set your club colours, add your crest, sponsor and squad number, preview instantly.</p></div>
   <div class="sqh-step"><b>03</b><h3>We handle the rest</h3><p>Send your order &mdash; we print the full strip and deliver. From &pound;25, all printing included.</p></div>
  </div>
 </div></section>
 <section class="sqh-cta"><div class="sqh-h2">Ready to kit out <em>your club?</em></div><a class="sqh-btn lg" href="/pages/kit-builder">Start Designing</a></section>
</div>
{% schema %}
{"name":"SQD Home","presets":[{"name":"SQD Home"}]}
{% endschema %}
